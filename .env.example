# Distill-Align Environment Configuration
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
# For OpenAI (default):
OPENAI_API_KEY="sk-..."

# For custom provider (overrides OPENAI_API_KEY):
# DISTILL_LLM_API_KEY="..."
# DISTILL_LLM_BASE_URL="https://api.openai.com/v1"
# DISTILL_LLM_MODEL="gpt-4o"

# --- Synthesis Defaults ---
# DISTILL_LLM_PROVIDER="openai"  # openai, ollama, vllm
# DISTILL_LLM_MAX_CONCURRENCY=5
# DISTILL_LLM_MAX_RPM=60
# DISTILL_LLM_TEMPERATURE=0.7

# --- Cache ---
# DISTILL_CACHE_DIR=".cache"

# --- Logging ---
# DISTILL_LOG_LEVEL="INFO"

# --- Export Defaults ---
# DISTILL_EXPORT_FORMATS="sharegpt,alpaca"
# DISTILL_EXPORT_OUTPUT_DIR="./output"
